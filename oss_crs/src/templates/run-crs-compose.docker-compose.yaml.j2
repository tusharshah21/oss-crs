networks:
  {{ crs_compose_name }}-network:
    driver: bridge
    name: {{ crs_compose_name }}-network
  {{ crs_compose_name }}-infra-only-network:
    driver: bridge
    name: {{ crs_compose_name }}-infra-only-network
  {%- for crs in crs_list %}
  {{ crs_compose_name }}-{{ crs.name }}-network:
    driver: bridge
    name: {{ crs_compose_name}}-{{ crs.name }}-network
  {%- endfor %}

volumes:
  crs-shared-volume:
    driver: local
    name: {{ crs_compose_name }}-shared-volume

services:
# crs.name can be different from name defined in crs.yaml; crs.name comes from crs-compose.yaml
{% for crs in crs_list %}
{% for module_name, module_config in crs.config.crs_run_phase.modules.items() %}
{% if module_config.dockerfile %}
  {{ crs.name }}_{{ module_name }}:
    privileged: true
    build:
      context: {{ crs.crs_path }}
      dockerfile: {{ resolve_dockerfile(crs.crs_path, module_config.dockerfile) }}
      additional_contexts:
        libcrs: {{ libCRS_path }}
      args:
        - target_base_image={{target.get_docker_image_name()}}
        - crs_version={{ crs.config.version }}
    environment:
{%- for env_key, env_value in module_envs[crs.name + "_" + module_name].items() %}
      - {{ env_key }}={{ env_value }}
{%- endfor %}
{%- if llm_context is defined and llm_context.mode == "internal" %}
    depends_on:
      oss-crs-litellm-key-gen:
        condition: service_completed_successfully
{%- endif %}
{%- if cgroup_parents and crs.name in cgroup_parents %}
    # Using cgroup-parent mode: resources managed by parent cgroup
    cgroup_parent: "{{ cgroup_parents[crs.name] }}"
{%- else %}
    cpuset: "{{ crs.resource.cpuset }}"
    mem_limit: "{{ crs.resource.memory }}"
{%- endif %}
    volumes:
      - {{ work_dir.get_build_output_dir(crs.name, target, build_id, sanitizer) }}:/OSS_CRS_BUILD_OUT_DIR:ro
      - {{ work_dir.get_submit_dir(crs.name, target, run_id, sanitizer) }}:/OSS_CRS_SUBMIT_DIR:rw
      - {{ work_dir.get_shared_dir(crs.name, target, run_id, sanitizer) }}:/OSS_CRS_SHARED_DIR:rw
      - {{ work_dir.get_log_dir(crs.name, target, run_id, sanitizer) }}:/OSS_CRS_LOG_DIR:rw
{%- if fetch_dir %}
      - {{ fetch_dir }}:/OSS_CRS_FETCH_DIR:ro
{%- endif %}
{%- if bug_fix_ensemble and not crs.config.is_bug_fixing_ensemble %}
    attach: false
{%- endif %}
    networks:
      {{ crs_compose_name }}-{{ crs.name }}-network:
        aliases:
          - {{module_name}}.{{ crs.name }}
      {{ crs_compose_name }}-network:
{% endif %}
{% endfor %}
{% endfor %}
  ###########################################
  # OSS-CRS-INFRA-SERVICES
  # - oss-crs-litellm
  # - oss-crs-postgres
{% if llm_context is defined and llm_context.mode == "internal" %}
  ###########################################
  # OSS-CRS-LITELLM
  ###########################################
  oss-crs-litellm:
    image: {{ litellm_image }}
    attach: false
    restart: on-failure:3
    depends_on:
      oss-crs-postgres:
        condition: service_healthy
    environment:
      - LITELLM_MASTER_KEY={{ llm_context.litellm_master_key }}
      - DATABASE_URL=postgresql://{{ postgres_user }}:{{ llm_context.postgres_password }}@{{ postgres_host }}:{{ postgres_port }}/{{ postgres_user }}
    {%- for key, value in llm_context.litellm_env.items() %}
      - {{ key }}={{ value }}
    {%- endfor %}
    volumes:
      - {{ llm_context.litellm_config_path }}:/app/config.yaml:ro
    networks:
      {{ crs_compose_name }}-infra-only-network:
      {{ crs_compose_name }}-network:
        aliases:
          - litellm.oss-crs
    command: --config /app/config.yaml
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:4000/health/liveliness')\""]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 15s
  oss-crs-postgres:
    image: {{ postgres_image }}
    attach: false
    restart: on-failure:3
    environment:
      - POSTGRES_USER={{ postgres_user }}
      - POSTGRES_PASSWORD={{ llm_context.postgres_password }}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_user }} -h localhost -p {{ postgres_port }}"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      {{ crs_compose_name }}-infra-only-network:
        aliases:
          - {{ postgres_host }}
  oss-crs-litellm-key-gen:
    image: {{ crs_compose_name }}-oss-crs-litellm-key-gen:latest
    attach: false
    build:
      context: {{ oss_crs_infra_root_path }}/litellm-key-gen
      dockerfile: {{ oss_crs_infra_root_path }}/litellm-key-gen/Dockerfile
    depends_on:
      oss-crs-litellm:
        condition: service_healthy
    environment:
      - LITELLM_MASTER_KEY={{ llm_context.litellm_master_key }}
      - LITELLM_API_URL={{ litellm_internal_url }}
    networks:
      {{ crs_compose_name }}-network:
    volumes:
      - {{ llm_context.key_gen_request_path }}:/key_gen_request.yaml:ro
  ###########################################
{% endif %}
  ###########################################
  # OSS-CRS-EXCHANGE SIDECAR
  ###########################################
{%- if exchange_dir %}
  oss-crs-exchange:
    build:
      context: {{ oss_crs_infra_root_path }}/exchange
    attach: false
    restart: on-failure:3
    volumes:
      - {{ exchange_dir }}:/OSS_CRS_EXCHANGE_DIR:rw
{%- for crs in crs_list %}
{%- if not crs.config.is_bug_fixing_ensemble %}
      - {{ work_dir.get_submit_dir(crs.name, target, run_id, sanitizer) }}:/submit/{{ crs.name }}:ro
{%- endif %}
{%- endfor %}
    networks:
      {{ crs_compose_name }}-infra-only-network:
{%- endif %}
  ###########################################
  # OSS-CRS-LIFECYCLE SIDECAR
  ###########################################
{#- Collect non-builder, non-ensemble bug-fixing CRS services #}
{%- set watch_services = [] %}
{%- for crs in crs_list %}
{%- if not crs.config.is_bug_fixing_ensemble and crs.config.is_bug_fixing %}
{%- for module_name, module_config in crs.config.crs_run_phase.modules.items() %}
{%- if module_config.dockerfile %}
{%- if watch_services.append(crs.name ~ "_" ~ module_name) %}{% endif %}
{%- endif %}
{%- endfor %}
{%- endif %}
{%- endfor %}
{%- if bug_fix_ensemble and exchange_dir and watch_services %}
  oss-crs-lifecycle:
    build:
      context: {{ oss_crs_infra_root_path }}/lifecycle
    attach: false
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - {{ exchange_dir }}:/OSS_CRS_EXCHANGE_DIR:rw
    environment:
      - COMPOSE_PROJECT={{ crs_compose_name }}
      - WATCH_SERVICES={{ watch_services | join(",") }}
    networks:
      {{ crs_compose_name }}-infra-only-network:
{%- endif %}
  ###########################################
  # OSS-CRS-BUILDER-SIDECAR
  ###########################################
  oss-crs-builder-sidecar:
    build:
      context: {{ oss_crs_infra_root_path }}/builder-sidecar
    attach: false
    restart: on-failure:3
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - {{ rebuild_out_dir }}:/rebuild_out:rw
    environment:
      - REBUILD_OUT_DIR=/rebuild_out
      - BASE_IMAGE={{ target.get_docker_image_name() }}
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:8080/health || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 5
      start_period: 15s
    networks:
      {{ crs_compose_name }}-network:
        aliases:
{%- for crs in crs_list %}
          - builder-sidecar.{{ crs.name }}
{%- endfor %}
  ###########################################
  # OSS-CRS-RUNNER-SIDECAR
  ###########################################
  oss-crs-runner-sidecar:
    build:
      context: {{ oss_crs_infra_root_path }}/runner-sidecar
    attach: false
    restart: on-failure:3
    volumes:
      - {{ rebuild_out_dir }}:/out:ro
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:8080/health || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 5
      start_period: 30s
    networks:
      {{ crs_compose_name }}-network:
        aliases:
{%- for crs in crs_list %}
          - runner-sidecar.{{ crs.name }}
{%- endfor %}
